{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://icicso.local/schemas/evidence-intelligence/provenance.schema.json",
  "title": "Provenance",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "source_system",
    "captured_at",
    "captured_by",
    "chain_of_custody",
    "license_status",
    "attestation_status",
    "canonical_id",
    "version",
    "status"
  ],
  "properties": {
    "source_system": { "type": "string", "minLength": 1 },
    "captured_at": { "type": "string", "format": "date-time" },
    "captured_by": { "type": "string", "minLength": 1 },
    "chain_of_custody": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step", "actor", "timestamp"],
        "properties": {
          "step": { "type": "string", "minLength": 1 },
          "actor": { "type": "string", "minLength": 1 },
          "timestamp": { "type": "string", "format": "date-time" },
          "hash": { "type": ["string", "null"] },
          "note": { "type": ["string", "null"] }
        }
      }
    },
    "license_status": { "type": "string", "enum": ["licensed", "open-access", "institutional-use-only", "restricted"] },
    "attestation_status": { "type": "string", "enum": ["pending", "attested", "rejected"] },
    "review_policy": { "type": ["string", "null"] },
    "canonical_id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "effective_from": { "type": ["string", "null"], "format": "date" },
    "effective_to": { "type": ["string", "null"], "format": "date" },
    "status": { "type": "string", "enum": ["draft", "under-review", "approved", "active", "superseded", "deprecated"] }
  }
}
