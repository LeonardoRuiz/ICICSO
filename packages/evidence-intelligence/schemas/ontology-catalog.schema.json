{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://icicso.local/schemas/evidence-intelligence/ontology-catalog.schema.json",
  "title": "Ontology Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "catalogId",
    "code",
    "label",
    "description",
    "usageNotes",
    "entries",
    "constraints"
  ],
  "properties": {
    "catalogId": { "type": "string", "minLength": 1 },
    "code": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "label": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "usageNotes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "code", "label", "description", "usageNotes"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "code": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "label": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "usageNotes": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": true,
      "required": ["uniqueFields", "requiredFields"],
      "properties": {
        "uniqueFields": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "requiredFields": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
