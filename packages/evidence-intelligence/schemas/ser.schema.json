{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://icicso.local/schemas/evidence-intelligence/ser.schema.json",
  "title": "Structured Evidence Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ser_id",
    "linked_source_ids",
    "pico",
    "population_details",
    "intervention_details",
    "outcome_objects",
    "effect_estimates",
    "follow_up_period",
    "bias_limitations",
    "applicability_assessment",
    "operational_relevance",
    "decision_readiness",
    "evidence_grading",
    "provenance",
    "review"
  ],
  "properties": {
    "ser_id": { "type": "string", "pattern": "^SER-[A-Z0-9_-]{6,}$" },
    "linked_source_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^EDOC-[A-Z0-9_-]{6,}$" } },
    "pico": {
      "type": "object",
      "additionalProperties": false,
      "required": ["population", "intervention", "outcomes"],
      "properties": {
        "population": { "type": "string", "minLength": 1 },
        "intervention": { "type": "string", "minLength": 1 },
        "comparator": { "type": ["string", "null"] },
        "outcomes": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "population_details": { "type": "object", "additionalProperties": true },
    "intervention_details": { "type": "object", "additionalProperties": true },
    "comparator_details": { "type": ["object", "null"], "additionalProperties": true },
    "outcome_objects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["outcome_class", "effect_direction"],
        "properties": {
          "outcome_class": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "effect_direction": { "type": "string", "enum": ["benefit", "harm", "no-benefit", "inconclusive", "mixed"] },
          "measure": { "type": ["string", "null"] }
        }
      }
    },
    "effect_estimates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["measure_type", "value"],
        "properties": {
          "measure_type": { "type": "string", "enum": ["rr", "or", "hr", "ard", "mean-difference", "diagnostic-accuracy", "narrative"] },
          "value": { "type": ["number", "string"] },
          "confidence_interval": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "required": ["lower", "upper"],
            "properties": {
              "lower": { "type": "number" },
              "upper": { "type": "number" }
            }
          }
        }
      }
    },
    "follow_up_period": { "type": "string", "minLength": 1 },
    "bias_limitations": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "applicability_assessment": { "$ref": "https://icicso.local/schemas/evidence-intelligence/applicability.schema.json" },
    "operational_relevance": { "type": "string", "enum": ["low", "moderate", "high", "transformational"] },
    "decision_readiness": { "type": "string", "enum": ["ready-for-execution", "ready-with-local-review", "synthesis-required", "contextual-only", "not-ready"] },
    "evidence_grading": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_level", "certainty"],
      "properties": {
        "evidence_level": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "certainty": { "type": "string", "enum": ["very-high", "high", "moderate", "low", "very-low", "unknown"] }
      }
    },
    "provenance": { "$ref": "https://icicso.local/schemas/evidence-intelligence/provenance.schema.json" },
    "review": { "$ref": "https://icicso.local/schemas/evidence-intelligence/review-metadata.schema.json" }
  }
}
