{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://icicso.local/schemas/evidence-intelligence/evidence-classification.schema.json",
  "title": "Evidence Classification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "classification_id",
    "evidence_type",
    "evidence_level",
    "clinical_functions",
    "effect_direction",
    "certainty",
    "time_horizons"
  ],
  "properties": {
    "classification_id": { "type": "string", "pattern": "^ECLS-[A-Z0-9_-]{6,}$" },
    "evidence_type": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "evidence_level": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "clinical_functions": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" } },
    "intervention_classes": { "type": "array", "items": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" } },
    "effect_direction": { "type": "string", "enum": ["benefit", "harm", "no-benefit", "inconclusive", "mixed"] },
    "certainty": { "type": "string", "enum": ["very-high", "high", "moderate", "low", "very-low", "unknown"] },
    "time_horizons": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" } }
  }
}
