{
  "name": "@icicso/evidence-intelligence",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "files": [
    "src",
    "docs",
    "schemas",
    "ontology",
    "seeds",
    "README.md"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./api": "./src/api/index.ts",
    "./contracts": "./src/contracts/index.ts",
    "./models": "./src/models/index.ts",
    "./artifacts": "./src/artifacts/index.ts",
    "./validators": "./src/validators/index.ts",
    "./mappers": "./src/mappers/index.ts",
    "./engines": "./src/engines/index.ts",
    "./seeds": "./src/seeds/index.ts",
    "./schemas/evidence-document": "./schemas/evidence-document.schema.json",
    "./schemas/evidence-source": "./schemas/evidence-source.schema.json",
    "./schemas/evidence-classification": "./schemas/evidence-classification.schema.json",
    "./schemas/ser": "./schemas/ser.schema.json",
    "./schemas/eo": "./schemas/eo.schema.json",
    "./schemas/provenance": "./schemas/provenance.schema.json",
    "./schemas/applicability": "./schemas/applicability.schema.json",
    "./schemas/operational-context": "./schemas/operational-context.schema.json",
    "./schemas/conflict-rule": "./schemas/conflict-rule.schema.json",
    "./schemas/review-metadata": "./schemas/review-metadata.schema.json",
    "./schemas/ontology-catalog": "./schemas/ontology-catalog.schema.json",
    "./ontology/evidence-types": "./ontology/evidence-types/catalog.json",
    "./ontology/evidence-levels": "./ontology/evidence-levels/catalog.json",
    "./ontology/interventions": "./ontology/interventions/catalog.json",
    "./ontology/outcomes": "./ontology/outcomes/catalog.json",
    "./ontology/clinical-functions": "./ontology/clinical-functions/catalog.json",
    "./ontology/time-horizons": "./ontology/time-horizons/catalog.json",
    "./ontology/uncertainty": "./ontology/uncertainty/catalog.json",
    "./ontology/certainty-levels": "./ontology/certainty-levels/catalog.json",
    "./ontology/jurisdictions": "./ontology/jurisdictions/catalog.json",
    "./ontology/conflict-rules": "./ontology/conflict-rules/catalog.json",
    "./ontology/applicability-dimensions": "./ontology/applicability-dimensions/catalog.json",
    "./ontology/implementation-complexity": "./ontology/implementation-complexity/catalog.json",
    "./ontology/effect-direction": "./ontology/effect-direction/catalog.json",
    "./ontology/evidence-decay": "./ontology/evidence-decay/catalog.json",
    "./ontology/provenance-minimum-set": "./ontology/provenance-minimum-set/catalog.json",
    "./ontology/operational-relevance": "./ontology/operational-relevance/catalog.json"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "validate:examples": "node ./tools/run-validation.mjs",
    "test:validation": "node ./tests/run-tests.mjs",
    "test:contracts": "npx tsc -p tsconfig.json && node ./dist/tests/interchange-contracts.test.js",
    "test:mapping": "npx tsc -p tsconfig.json && node ./dist/tests/mapping.test.js",
    "test:seeds": "npx tsc -p tsconfig.json && node ./dist/tests/seed-bundles.test.js"
  }
}
