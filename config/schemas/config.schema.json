  "required": [
    "NODE_ENV",
    "LOG_LEVEL",
    "DATABASE_URL",
    "POSTGRES_HOST",
    "POSTGRES_PORT",
    "POSTGRES_DB",
    "POSTGRES_USER",
    "POSTGRES_PASSWORD",
    "REDIS_URL",
    "REDIS_HOST",
    "REDIS_PORT",
    "JWT_SECRET",
    "AUTH_ISSUER",
    "AUTH_AUDIENCE",
    "INTERNAL_SERVICE_TOKEN",
    "MINIO_ENDPOINT",
    "MINIO_BUCKET",
    "MINIO_ACCESS_KEY",
    "MINIO_SECRET_KEY",
    "GATEWAY_API_PORT",
    "INGESTION_SERVICE_PORT",
    "TERMINOLOGY_ENGINE_URL",
    "OBSERVABILITY_GRAFANA_ADMIN_USER",
    "OBSERVABILITY_GRAFANA_ADMIN_PASSWORD",
    "OBSERVABILITY_POSTGRES_EXPORTER_DSN",
    "OBSERVABILITY_REDIS_EXPORTER_ADDR"
  ]
}
