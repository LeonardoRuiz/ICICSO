{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://icicso.local/schemas/evidence/ser.schema.json",
  "title": "SER",
  "description": "Resumen estructurado de evidencia derivado de un documento fuente.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ser_id",
    "source_document_id",
    "title",
    "domain",
    "language",
    "methodology_status",
    "summary_text",
    "created_at_utc",
    "created_by",
    "version_id",
    "status"
  ],
  "properties": {
    "ser_id": {
      "type": "string",
      "pattern": "^SER-[A-Z0-9_-]{8,}$"
    },
    "source_document_id": {
      "type": "string",
      "pattern": "^DOC-[A-Z0-9]{12}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "language": {
      "type": "string",
      "minLength": 2
    },
    "doi": {
      "type": [
        "string",
        "null"
      ]
    },
    "loe": {
      "type": [
        "string",
        "null"
      ]
    },
    "cor": {
      "type": [
        "string",
        "null"
      ]
    },
    "methodology_status": {
      "type": "string",
      "enum": [
        "draft",
        "under_review",
        "approved",
        "deprecated"
      ]
    },
    "summary_text": {
      "type": "string",
      "minLength": 1
    },
    "key_findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "minLength": 1
    },
    "version_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "superseded",
        "deprecated"
      ]
    }
  }
}

