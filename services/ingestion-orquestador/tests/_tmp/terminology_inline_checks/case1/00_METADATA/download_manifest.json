{
  "datasets": [
    {
      "dataset": "ICD10",
      "mode": "public",
      "handler": "download_icd10",
      "target_file": "icd10_claml.xml",
      "urls": [
        "https://icdcdn.who.int/icd10/ClAML/current/icd10_claml.xml",
        "https://icdcdn.who.int/icd10/2019/en/icd10.xml",
        "https://icd.who.int/browse10/Content/datafiles/icd10cm_tabular_2024.xml"
      ]
    },
    {
      "dataset": "ICD11",
      "mode": "credentialed",
      "handler": "download_icd11",
      "target_file": "icd11_mms.json",
      "notes": "Puede operar con token WHO o con credenciales client credentials."
    },
    {
      "dataset": "LOINC",
      "mode": "credentialed",
      "handler": "download_loinc",
      "target_file": "loinc.zip",
      "notes": "Requiere cuenta/licencia LOINC y login v\u00e1lido."
    },
    {
      "dataset": "RXNORM",
      "mode": "public",
      "handler": "download_rxnorm",
      "target_file": "rxnorm.zip",
      "urls": [
        "https://download.nlm.nih.gov/umls/kss/rxnorm/RxNorm_full_current.zip",
        "https://download.nlm.nih.gov/umls/kss/rxnorm/RxNorm_full_01012026.zip"
      ]
    },
    {
      "dataset": "UCUM",
      "mode": "public",
      "handler": "download_ucum",
      "target_file": "ucum.xml",
      "urls": [
        "https://ucum.org/ucum-essence.xml"
      ]
    },
    {
      "dataset": "HL7_THO",
      "mode": "public",
      "handler": "download_hl7_tho",
      "target_file": "tho.tgz"
    },
    {
      "dataset": "ATC_DDD",
      "mode": "public",
      "handler": "download_atc_ddd",
      "target_file": "atc_index.csv"
    },
    {
      "dataset": "SNOMED_CT",
      "mode": "manual",
      "handler": "create_snomed_placeholder",
      "target_file": "README.txt",
      "notes": "No se automatiza evasi\u00f3n de licencia; se deja pendiente de descarga autorizada."
    }
  ]
}