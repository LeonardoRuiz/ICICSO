    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "targets": [
        { "expr": "sum by (route, error_code) (rate(icicso_engine_failures_total[5m]))", "legendFormat": "{{route}} {{error_code}}", "refId": "A" }
      ],
      "title": "Engine Failures",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
